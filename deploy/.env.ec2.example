# Hostname only, without https://. Its DNS A record must point to this EC2 instance.
API_DOMAIN=api.example.com

DATABASE_URL=postgresql+psycopg://eupugs_admin:change-me@your-rds-endpoint:5432/eupugs
SESSION_SECRET=replace-with-a-long-random-value
SESSION_COOKIE_NAME=hostedpugs_session
SESSION_MAX_AGE_SECONDS=2592000

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://api.example.com/auth/discord/callback
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_LOG_CHANNEL_ID=
DISCORD_ADMIN_ROLE_IDS=

# Exact GitHub Pages origin, with no trailing slash.
FRONTEND_ORIGIN=https://your-github-user.github.io
API_BASE_URL=https://api.example.com
ENABLE_AUTO_MIGRATE=true
LOGSTF_SYNC_LIMIT=20
